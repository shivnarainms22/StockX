# StockX — API Keys
# Add the keys you have. StockX tries NVIDIA NIM first, then Anthropic, then OpenAI.
# No spaces around the = sign.
NVIDIA_API_KEY='nvapi-your-key-here'
ANTHROPIC_API_KEY='sk-ant-your-key-here'
OPENAI_API_KEY='sk-your-key-here'

# Web search (leave blank to use DuckDuckGo scrape fallback)
# SEARCH_PROVIDER=brave        # brave | tavily | duckduckgo
# SEARCH_API_KEY=your-key-here

# Agent tuning
# AGENT_MAX_STEPS=12
# AGENT_MAX_CONTEXT_TOKENS=102400

# Watchlist auto-refresh interval in minutes (0 = disabled)
# WATCHLIST_REFRESH_INTERVAL=15

# Memory storage paths
# MEMORY_JSONL_PATH=memory/memory.jsonl
# MEMORY_CHROMA_DIR=memory/chroma_db
# MEMORY_JSONL_MAX_ENTRIES=500

# Theme: dark | light
# APP_THEME=dark
